generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  fullName      String    @map("full_name")
  email         String    @unique
  passwordHash  String    @map("password_hash")
  oauthProvider String?   @map("oauth_provider")
  oauthId       String?   @map("oauth_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  userRoles UserRole[]

  @@map("users")
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id     String @id @default(uuid())
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("audit_logs")
}

model IncomeCategory {
  id          String    @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")
  incomes Income[]
  @@map("income_categories")
}

model ExpenseCategory {
  id          String    @id @default(uuid())
  groupName   String    @map("group_name")
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

    expenses Expense[]

  @@map("expense_categories")
}

model Income {
  id               String    @id @default(uuid())
  transactionDate  DateTime  @map("transaction_date") @db.Date
  amount           Decimal   @db.Decimal(15, 2)
  incomeCategoryId String    @map("income_category_id")
  incomeSource     String?   @map("income_source")
  clientName       String?   @map("client_name")
  paymentMethod    String    @map("payment_method")
  referenceNumber  String?   @map("reference_number")
  invoiceNumber    String?   @map("invoice_number")
  description      String?

  createdBy String    @map("created_by")
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  category IncomeCategory @relation(fields: [incomeCategoryId], references: [id])

  @@index([transactionDate])
  @@index([deletedAt])
  @@index([amount])
  @@map("income")
}

model Expense {
  id                String    @id @default(uuid())
  expenseDate       DateTime  @map("expense_date") @db.Date
  amount            Decimal   @db.Decimal(15, 2)
  expenseCategoryId String    @map("expense_category_id")
  vendorName        String?   @map("vendor_name")
  paymentMethod     String    @map("payment_method")
  billNumber        String?   @map("bill_number")
  description       String?

  createdBy String    @map("created_by")
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  category ExpenseCategory @relation(fields: [expenseCategoryId], references: [id])

  @@index([expenseDate])
  @@index([deletedAt])
  @@index([amount])
  @@map("expense")
}

model Note {
  id          String    @id @default(uuid())
  title       String
  description String
  colorLabel  String?   @map("color_label")
  isPinned    Boolean   @default(false) @map("is_pinned")
  isArchived  Boolean   @default(false) @map("is_archived")

  createdBy String    @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("notes")
}

model Reminder {
  id           String    @id @default(uuid())
  title        String
  description  String?
  reminderDate DateTime  @map("reminder_date") @db.Date
  reminderTime String?   @map("reminder_time")
  priority     String
  status       String    @default("PENDING")
  repeat       String    @default("NONE")

  createdBy String    @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([reminderDate])
  @@index([status])
  @@map("reminders")
}


model Attachment {
  id         String    @id @default(uuid())
  entityType String    @map("entity_type") // "income" | "expense" | "reminder"
  entityId   String    @map("entity_id")
  fileName   String    @map("file_name")
  fileSize   BigInt    @map("file_size")
  mimeType   String    @map("mime_type")
  storageKey String    @map("storage_key")
  storageUrl String    @map("storage_url")
  provider   String

  uploadedBy String    @map("uploaded_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")

  // entity_type + entity_id is a polymorphic reference (income | expense | reminder).
  // Postgres/Prisma can't enforce one FK constraint across 3 target tables, so this
  // link is validated at the application layer (see attachment.service.ts), not via @relation.

  @@index([entityType, entityId])
  @@map("attachments")
}